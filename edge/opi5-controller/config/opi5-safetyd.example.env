# opi5-safetyd.example.env -- OPi5 safety daemon configuration
# Copy to /etc/edge-ai-safety-monitor/opi5-safetyd.env and fill real values
# 2026-06-09 实测确认

# AI service (OPi5 localhost)
OPI5_URL=http://127.0.0.1:8080

# Flask backend (OPi5 all-in-one: same host)
BACKEND_URL=http://127.0.0.1:5000

DEVICE_ID=labbox_001

# GPIO pins (2026-06-09 实测)
GPIO_PIR=139
GPIO_ACTIVE_HIGH=1
GPIO_FLAME=28
GPIO_FLAME_ACTIVE_HIGH=0
GPIO_MQ2=49
GPIO_MQ2_ACTIVE_HIGH=0
GPIO_BUZZER=35
GPIO_BUZZER_ACTIVE_HIGH=0

# RGB via GPIO (PCA9685 不可用)
RGB_BACKEND=gpio
GPIO_RGB_R=48
GPIO_RGB_R_ACTIVE_HIGH=1
GPIO_RGB_G=50
GPIO_RGB_G_ACTIVE_HIGH=1
GPIO_RGB_B=52
GPIO_RGB_B_ACTIVE_HIGH=1

# Water gun via MOS (pin 11, GPIO138)
GPIO_WATER_GUN=138
GPIO_WATER_GUN_ACTIVE_HIGH=1

# Servo via OPi5 hardware PWM (pin 7, pwmchip4)
SERVO_PWM_CHIP=4
SERVO_PWM_CHANNEL=0
SERVO_PERIOD_NS=20000000
SERVO_PULSE_MIN_NS=500000
SERVO_PULSE_CENTER_NS=1500000
SERVO_PULSE_MAX_NS=2500000

# I2C for OLED + MPU6050 (I2C1, pin 16/18)
OLED_ENABLE=0
OLED_BUS=/dev/i2c-1
OLED_ADDR=0x3C

# USB camera
CAPTURE_DEVICE=/dev/video0

BASE_DIR=/opt/edge-ai-safety-monitor
POST_NORMAL=0
INTERVAL_SEC=2

# --- Patrol (servo sweep) ---
PATROL_ENABLE=0
PATROL_INTERVAL_SEC=30
PATROL_ANGLES=60,90,120
PATROL_SETTLE_MS=500
PATROL_SETTLE_CAPTURE_MS=2000
PATROL_AI_ENABLE=1
PATROL_POST_EVENT=1
PATROL_AI_TIMEOUT_SEC=10

# --- Water gun on flame ---
# Requires PUMP_ENABLE=1 (or direct GPIO control)
WATER_GUN_ON_FLAME_ENABLE=0
# Reuses SPRAY_MAX_MS and SPRAY_COOLDOWN_MS for timing
SPRAY_MAX_MS=800
SPRAY_COOLDOWN_MS=5000
