#!/bin/sh
# S45wifi-client - i.MX6ULL WiFi auto-connect for RTL8723BU
# Copy to /etc/init.d/S45wifi-client on i.MX
# Requires: /etc/wpa_supplicant_imx.conf (real config, not committed)
#
# Usage: S45wifi-client {start|stop|restart|status}

DAEMON="wpa_supplicant"
WPA_CONF="/etc/wpa_supplicant_imx.conf"
WPA_PIDFILE="/var/run/wpa_supplicant-wlan0.pid"
IFACE="wlan0"
DRIVER="nl80211"
LOGFILE="/tmp/wifi-client.log"

start() {
    if [ ! -f "$WPA_CONF" ]; then
        echo "[$0] $WPA_CONF not found, skipping WiFi" | tee -a "$LOGFILE"
        return 1
    fi

    echo "[$0] Starting WiFi on $IFACE" | tee -a "$LOGFILE"

    # Wait for wlan0 to appear (up to 30s)
    i=0
    while [ $i -lt 30 ]; do
        if ip link show "$IFACE" >/dev/null 2>&1; then
            break
        fi
        sleep 1
        i=$((i + 1))
    done

    if ! ip link show "$IFACE" >/dev/null 2>&1; then
        echo "[$0] $IFACE not found after 30s" | tee -a "$LOGFILE"
        return 1
    fi

    ip link set "$IFACE" up 2>/dev/null
    sleep 2

    # Start wpa_supplicant in background
    $DAEMON -i "$IFACE" -c "$WPA_CONF" -D "$DRIVER" -B -P "$WPA_PIDFILE" >> "$LOGFILE" 2>&1

    # Wait for connection (up to 30s)
    i=0
    while [ $i -lt 30 ]; do
        if iw dev "$IFACE" link 2>/dev/null | grep -q "Connected\|SSID"; then
            echo "[$0] WiFi connected" | tee -a "$LOGFILE"
            # Get IP via DHCP
            udhcpc -i "$IFACE" -q -n -t 5 >> "$LOGFILE" 2>&1 &
            return 0
        fi
        sleep 1
        i=$((i + 1))
    done

    echo "[$0] WiFi connection timeout" | tee -a "$LOGFILE"
    return 1
}

stop() {
    echo "[$0] Stopping WiFi on $IFACE" | tee -a "$LOGFILE"
    killall udhcpc 2>/dev/null
    if [ -f "$WPA_PIDFILE" ]; then
        kill "$(cat $WPA_PIDFILE)" 2>/dev/null
        rm -f "$WPA_PIDFILE"
    fi
    killall $DAEMON 2>/dev/null
    ip link set "$IFACE" down 2>/dev/null
}

status() {
    if iw dev "$IFACE" link 2>/dev/null | grep -q "Connected\|SSID"; then
        echo "WiFi connected on $IFACE"
        iw dev "$IFACE" link 2>/dev/null
        ip addr show "$IFACE" 2>/dev/null | grep "inet "
    else
        echo "WiFi not connected"
    fi
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) stop; sleep 2; start ;;
    status)  status ;;
    *)       echo "Usage: $0 {start|stop|restart|status}" ;;
esac
