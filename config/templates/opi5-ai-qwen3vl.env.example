# OPi5 AI Service environment — Qwen3-VL real AI mode
# This file is merged into /etc/edge-ai-safety-monitor.env for all-in-one deploy.
# If using standalone AI service, copy to /etc/edge-ai/opi5-ai-qwen3vl.env.
# Do NOT commit the real file.

AI_BACKEND=qwen3vl
QWEN3VL_MODE=worker
QWEN3VL_BINARY=/home/orangepi/qwen3vl_worker_build/qwen3vl_worker
QWEN3VL_ENCODER=/home/orangepi/models/qwen3vl_models/qwen3vl_2b_vision.rknn
QWEN3VL_LLM=/home/orangepi/models/qwen3vl_models/qwen3vl_2b_w8a8_base.rkllm
QWEN3VL_CORE_NUM=3
OPI5_AI_PORT=8080

# Clear proxy for local NPU/LLM communication
no_proxy=*
NO_PROXY=*
