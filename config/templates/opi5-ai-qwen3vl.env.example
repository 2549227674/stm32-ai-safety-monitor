# OPi5 AI Service environment — Qwen3-VL real AI mode
# Copy to /etc/edge-ai/opi5-ai-qwen3vl.env and fill real paths.
# Do NOT commit the real file (model paths, tokens are secrets).

AI_BACKEND=qwen3vl
QWEN3VL_MODE=worker
QWEN3VL_ENCODER=/home/orangepi/models/qwen3vl_models/qwen3vl_2b_vision.rknn
QWEN3VL_LLM=/home/orangepi/models/qwen3vl_models/qwen3vl_2b_w8a8_base.rkllm
QWEN3VL_CORE_NUM=3
OPI5_AI_PORT=8080

# Clear proxy for local NPU/LLM communication
no_proxy=*
NO_PROXY=*
