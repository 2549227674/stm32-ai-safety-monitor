[Unit]
Description=OPi5 Device Agent (video, telemetry, heartbeat)
After=network-online.target opi5-ai-qwen3vl.service
Wants=network-online.target

[Service]
Type=simple
User=orangepi
WorkingDirectory=/opt/edge-ai-safety-monitor/opi5-device-agent
EnvironmentFile=-/etc/edge-ai/opi5-device-agent.env
ExecStart=/usr/bin/python3 app.py
Restart=always
RestartSec=5
StandardOutput=append:/var/log/opi5-device-agent.log
StandardError=append:/var/log/opi5-device-agent.log

[Install]
WantedBy=multi-user.target
