# /etc/edge-ai-safety-monitor.env — OPi5 all-in-one unified environment
# Copy to /etc/edge-ai-safety-monitor.env and customize.
# Do NOT commit the real file.

DEVICE_ID=edge-opi5-001

# --- Service ports (all on OPi5 localhost) ---
BACKEND_URL=http://127.0.0.1:5000
AI_URL=http://127.0.0.1:8080
OPI5_DEVICE_AGENT_URL=http://127.0.0.1:8090
AGENT_PORT=8090

# --- Camera ---
CAMERA_DEVICE=/dev/video0
VIDEO_MOCK=0
VIDEO_WIDTH=640
VIDEO_HEIGHT=480
VIDEO_FPS=30
VIDEO_JPEG_QUALITY=60

# --- Telemetry / heartbeat ---
HEARTBEAT_SEC=5
TELEMETRY_SAMPLE_SEC=1
TELEMETRY_BATCH_SEC=30
AI_OBSERVATION_INTERVAL_SEC=30
SAFETYD_STATUS_PATH=/opt/edge-ai-safety-monitor/run/opi5_safetyd_status.json

# --- SMTP (optional, for alert email) ---
ALERT_EMAIL_ENABLED=0
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL_TO=
SMTP_USE_TLS=1
ALERT_EMAIL_COOLDOWN_SECONDS=300
